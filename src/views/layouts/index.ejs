<!DOCTYPE html>
<html lang="id">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes" />
  <title>Jay Precensia</title>
  <!-- Bootstrap 5 CSS -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/css/bootstrap.min.css" rel="stylesheet" />
  <!-- Font Awesome 6 -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" />
  <!-- Google Font: Inter -->
  <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500;14..32,600;14..32,700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/login.style.css">
  <link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet">
</head>
<style>
  .input-icon {
    position: relative;
  }

  .input-icon i:first-child {
    position: absolute;
    left: 14px;
    top: 50%;
    transform: translateY(-50%);
    color: #9bb7c4;
    font-size: 1rem;
    z-index: 1;
  }

  .input-icon input {
    width: 100%;
    padding: 12px 50px 12px 42px;
    /* Tambah padding kanan untuk tombol */
    border: 1.5px solid #e2edf2;
    border-radius: 28px;
    font-size: 0.9rem;
    transition: all 0.2s;
    background: #ffffff;
    outline: none;
    color: #1e4a60;
  }

  .btn-show-password {
    position: absolute;
    right: 40px;
    top: 50%;
    transform: translateY(-50%);
    background: none;
    border: none;
    cursor: pointer;
    color: #9bb7c4;
    font-size: 1rem;
    padding: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: color 0.2s;
    z-index: 1;
  }

  .btn-show-password:hover {
    color: #2c5a6e;
  }

  .btn-show-password:focus {
    outline: none;
  }

  .media-side {
    background: linear-gradient(145deg, #2c5a6e, #1e3f4e);
    position: relative;
    overflow: hidden;
    min-height: 500px;
    --bg-blur: none;
  }

  /* Background blur dari video */
  .media-side::before {
    content: '';
    position: absolute;
    top: -10%;
    left: -10%;
    right: -10%;
    bottom: -10%;
    background-image: var(--bg-blur);
    background-size: cover;
    background-position: center;
    filter: blur(30px);
    z-index: 0;
    transition: background-image 0.3s ease;
  }

  /* Video utama - tidak dicrop */
  .media-side video,
  .media-side img {
    width: 60%;
    height: auto;
    max-width: 85%;
    max-height: 85%;
    object-fit: fill;
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    z-index: 2;
    border-radius: 16px;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
  }

  .media-side .overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(44, 90, 110, 0.2);
    z-index: 1;
  }

  .media-side .caption {
    position: absolute;
    bottom: 0px;
    left: 0;
    right: 0;
    text-align: center;
    color: white;
    z-index: 3;
    padding: 1rem;
    background: linear-gradient(transparent, rgba(0, 0, 0, 0.6));
    font-weight: 500;
    font-size: 1rem;
  }

  .bg-shapes {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    overflow: hidden;
    z-index: 0;
  }

  .shape {
    position: absolute;
    border-radius: 50%;
    background: rgba(140, 177, 194, 0.1);
    animation: float 20s infinite ease-in-out;
  }

  .shape-1 {
    width: 300px;
    height: 300px;
    top: -100px;
    left: -100px;
    animation-delay: 0s;
  }

  .shape-2 {
    width: 500px;
    height: 500px;
    bottom: -200px;
    right: -200px;
    animation-delay: 5s;
  }

  .shape-3 {
    width: 200px;
    height: 200px;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    animation-delay: 10s;
    opacity: 0.3;
  }

  .shape-4 {
    width: 150px;
    height: 150px;
    top: 20%;
    right: 10%;
    animation-delay: 3s;
  }

  .shape-5 {
    width: 250px;
    height: 250px;
    bottom: 10%;
    left: 5%;
    animation-delay: 7s;
  }
</style>

<body>
  <div class="bg-shapes">
    <div class="shape shape-1"></div>
    <div class="shape shape-2"></div>
    <div class="shape shape-3"></div>
    <div class="shape shape-4"></div>
    <div class="shape shape-5"></div>
  </div>
  <div class="login-container">
    <div class="media-side" id="mediaSide" data-aos="fade-right" data-aos-duration="1800">
      <video autoplay muted loop playsinline id="bgVideo" crossorigin="anonymous">
        <source src="/vid/gedung-stmik.mp4" type="video/mp4" />
        <img src="/img/icon/logo-jn.png" alt="Login visual" />
      </video>
      <canvas id="blurCanvas" style="display: none;"></canvas>
      <div class="overlay"></div>
      <div class="caption">
        <i class="fas fa-graduation-cap me-2"></i> Unggul dalam Menghasilkan Lulusan Berkualitas.
      </div>
    </div>

    <div class="form-side">
      <div class="role-tabs" id="roleTabs" data-aos="fade-left" data-aos-duration="400">
        <button class="role-btn active" data-role="student">
          <i class="fas fa-user-graduate"></i> Mahasiswa
        </button>
        <button class="role-btn" data-role="lecturer">
          <i class="fas fa-chalkboard-user"></i> Dosen
        </button>
      </div>

      <div data-aos="fade-left" data-aos-delay="1000">
        <h2 class="title-login" id="dynamicTitle"></h2>
        <p class="subtitle" id="dynamicSubtitle">
          Akses portal pembelajaran dan nilai Anda
        </p>
      </div>

      <!-- Error message untuk server-side validation -->
      <% if (error) { %>
      <div class="error-message show" id="serverErrorMessage">
        <i class="fas fa-exclamation-circle"></i>
        <span><%= error %></span>
        <button class="close-btn" onclick="this.parentElement.remove()">×</button>
      </div>
      <% } %>

      <% if (success) { %>
      <div class="success-message show" id="serverErrorMessage">
        <i class="fas fa-exclamation-circle"></i>
        <span><%= success %></span>
        <button class="close-btn" onclick="this.parentElement.remove()">×</button>
      </div>
      <% } %>

      <!-- Error message untuk client-side validation -->
      <div class="error-message" id="clientErrorMessage">
        <i class="fas fa-exclamation-circle"></i>
        <span id="errorText"></span>
        <button class="close-btn" onclick="this.parentElement.remove()">×</button>
      </div>

      <form action="/login" method="POST" id="loginForm">
        <input type="hidden" name="role" id="roleInput" value="student" />

        <div class="input-group-custom" data-aos="fade-left" data-aos-delay="200">
          <label><i class="far fa-id-card me-1"></i><span id="lbl-username">NIM atau BP</span></label>
          <div class="input-icon">
            <i class="fas fa-user-circle"></i>
            <input type="text" name="username" id="username" required autocomplete="off" autofocus />
          </div>
        </div>

        <div class="input-group-custom" data-aos="fade-left" data-aos-delay="400">
          <label><i class="fas fa-lock me-1"></i> Kata Sandi</label>
          <div class="input-icon">
            <i class="fas fa-key"></i>
            <input type="password" name="password" id="password" autocomplete="off" required />
            <button type="button" class="btn-show-password" id="togglePassword">
              <i class="fas fa-eye"></i>
            </button>
          </div>
        </div>

        <div class="d-flex justify-content-between align-items-center mt-2 mb-2" data-aos="zoom" data-aos-delay="1500">
          <a href="#" class="forgot-link">Lupa password?</a>
        </div>

        <button type="submit" class="btn-login" data-aos="fade-up" data-aos-delay="500">
          <i class="fas fa-arrow-right-to-bracket me-2"></i> Login
        </button>
      </form>

      <div class="demo-badge">
        <i class="fas fa-copyright me-1"></i>
        Designed & Developed by Alwan Aditia
      </div>
    </div>
  </div>

  <script>
    (function() {
      const video = document.getElementById('bgVideo');
      const mediaSide = document.getElementById('mediaSide');
      const canvas = document.getElementById('blurCanvas');

      if (!video || !mediaSide || !canvas) return;

      const ctx = canvas.getContext('2d');
      let captureInterval = null;

      function captureFrame() {
        if (video.paused || video.ended || video.readyState < 2) return;

        // Set canvas size to video dimensions
        canvas.width = video.videoWidth;
        canvas.height = video.videoHeight;

        // Draw current video frame to canvas
        ctx.drawImage(video, 0, 0, canvas.width, canvas.height);

        // Convert canvas to data URL and set as background
        const dataURL = canvas.toDataURL('image/jpeg', 0.5);
        mediaSide.style.setProperty('--bg-blur', `url(${dataURL})`);
      }

      video.addEventListener('play', function() {
        // Capture first frame immediately
        setTimeout(captureFrame, 100);

        // Capture frame every 2 seconds to update blur background
        if (captureInterval) clearInterval(captureInterval);
        captureInterval = setInterval(captureFrame, 2000);
      });

      video.addEventListener('ended', function() {
        if (captureInterval) clearInterval(captureInterval);
      });

      // Fallback: capture when video can play
      video.addEventListener('canplay', function() {
        captureFrame();
      });
    })();
  </script>
  <script src="/js/login.script.js"></script>
  <script>
    // Toggle password visibility
    const togglePassword = document.getElementById('togglePassword');
    const passwordInput = document.getElementById('password');

    if (togglePassword && passwordInput) {
      togglePassword.addEventListener('click', function() {
        // Toggle type input
        const type = passwordInput.getAttribute('type') === 'password' ? 'text' : 'password';
        passwordInput.setAttribute('type', type);

        // Toggle icon
        const icon = this.querySelector('i');
        if (icon.classList.contains('fa-eye')) {
          icon.classList.remove('fa-eye');
          icon.classList.add('fa-eye-slash');
        } else {
          icon.classList.remove('fa-eye-slash');
          icon.classList.add('fa-eye');
        }
      });
    }
  </script>
  <script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
  <script>
    AOS.init({
      once: false
    })
  </script>
</body>

</html>