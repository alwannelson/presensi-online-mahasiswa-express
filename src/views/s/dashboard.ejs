<% if (page === 'today') { %>

<!-- KONTEN HARI INI -->
<div class="content-card">
  <h5 class="mb-3">
    <i class="fas fa-calendar-alt me-2"></i>Jadwal Kuliah Hari Ini : <%= currentDay %>, <%= currentDate %>
  </h5>
  <div class="cards-container">
    <% if (rows && rows.length > 0) { %>
    <% rows.forEach((r, index) => { %>
    <div class="schedule-card">
      <div class="card-header">
        <div class="course-info">
          <h3 class="course-name" title="<%= r.course_name %>">
            <%= r.course_name.length > 40 ? r.course_name.substring(0, 40) + '...' : r.course_name %>
          </h3>
          <span class="credits-badge"><%= r.course_credits %> SKS</span>
        </div>
        <div class="class-info">
          <span class="class-name" title="<%= r.class_name %>">
            <i class="fas fa-location-dot"></i>
            <%= r.class_name.length > 30 ? r.class_name.substring(0, 30) + '...' : r.class_name %>
          </span>
        </div>
      </div>

      <div class="card-body">
        <div class="lecturer-info">
          <i class="fas fa-chalkboard-user"></i>
          <span title="<%= r.lecturer_name %>, <%= r.lecturer_degree %>">
            <strong id="lecturer_name"><%= r.lecturer_name %>, <%= r.lecturer_degree %></strong>
          </span>
        </div>

        <div class="schedule-time">
          <div class="time-item">
            <i class="fas fa-clock"></i>
            <span>Mulai: <strong><%= r.start %></strong></span>
          </div>
          <div class="time-item">
            <i class="fas fa-hourglass-end"></i>
            <span>Selesai: <strong><%= r.end %></strong></span>
          </div>
          <div class="time-item duration">
            <i class="fas fa-stopwatch"></i>
            <span>Durasi: <strong><%= r.durations || r.duration %></strong></span>
          </div>
        </div>
      </div>

      <div class="card-footer">
        <% if (r.attendance_status === 'hadir') { %>
        <button class="btn-attend disabled" disabled style="opacity: 2; cursor: not-allowed;">
          <i class="fas fa-check-circle" style="color: rgba(160, 255, 149, 0.814);"></i> Sudah Hadir
        </button>
        <% } else if (r.attendance_status === 'tidak_hadir') { %>
        <button class="btn-absent disabled" disabled style="opacity: 0.6; cursor: not-allowed;">
          <i class="fas fa-times-circle"></i> Sudah Tidak Hadir
        </button>
        <% } else { %>
        <a href="/s/today/present/<%= r.slug %>" class="btn-attend" data-matkul="<%= r.course_name %>" data-lecturer="<%= r.lecturer_name %>" data-id="<%= r.id_schedule %>" style="text-decoration: none;">
          <i class="fas fa-check-circle"></i> Hadir
        </a>
        <button class="btn-absent" data-matkul="<%= r.course_name %>" data-id="<%= r.id_schedule %>">
          <i class="fas fa-times-circle"></i> Tidak Hadir
        </button>

        <% } %>
      </div>
    </div>
    <!-- Load library terlebih dahulu -->
    <script>
      // Tombol Hadir
      // Event delegation - lebih aman untuk dynamic element
      const lecturerName = document.getElementById('lecturer_name').getHTML()
      document.body.addEventListener('click', async function(e) {
        // Cek apakah yang diklik adalah btn-attend atau di dalamnya
        const btn = e.target.closest('.btn-attend');
        if (!btn) return;

        e.preventDefault();

        // Cek apakah sudah diproses
        if (btn.hasAttribute('data-processed')) return;
        btn.setAttribute('data-processed', 'true');

        const matkul = btn.getAttribute('data-matkul');
        const lecturer = btn.getAttribute('data-lecturer');
        const url = btn.getAttribute('href');

        const confirmed = await JayPopup.confirm(
          'Konfirmasi Kehadiran',
          `Apakah Anda yakin mengambil presensi untuk mata kuliah:\n${matkul}\n\nDosen: ${lecturerName}`,
          'info'
        );

        if (confirmed) {
          window.location.href = url;
        }

        // Reset setelah selesai
        setTimeout(() => btn.removeAttribute('data-processed'), 500);
      });

      // Tombol Tidak Hadir
      document.querySelectorAll('.btn-absent').forEach(btn => {
        btn.addEventListener('click', async function(e) {
          const matkul = this.getAttribute('data-matkul');
          const lecturer = this.getAttribute('data-lecturer');

          if (typeof JayPopup === 'undefined') {
            console.error('JayPopup tidak tersedia!');
            return;
          }

          try {
            const confirmed = await JayPopup.confirm(
              'Konfirmasi Ketidakhadiran',
              `Apakah Anda yakin ingin mengisi status TIDAK HADIR untuk mata kuliah:\n${matkul}\n\nDosen: ${lecturer || '-'}`,
              'warning'
            );

            if (confirmed) {
              window.location.href = '/s/today';
            }
          } catch (error) {
            console.error('Error:', error);
          }
        });
      });
    </script>

    <style>
      /* Modern SweetAlert dengan Outline Button */
      .modern-swal {
        border-radius: 28px !important;
        padding: 25px !important;
        font-family: 'Inter', sans-serif !important;
      }

      /* Tombol YA solid */
      .btn-success-solid {
        background: #28a745 !important;
        color: white !important;
        border: none !important;
        border-radius: 12px !important;
        padding: 10px 25px !important;
        font-weight: 600 !important;
        transition: all 0.2s ease !important;
      }

      .btn-success-solid:hover {
        background: #218838 !important;
        transform: translateY(-2px) !important;
        box-shadow: 0 4px 12px rgba(40, 167, 69, 0.3) !important;
      }

      /* Tombol YA solid untuk danger */
      .btn-danger-solid {
        background: #dc3545 !important;
        color: white !important;
        border: none !important;
        border-radius: 12px !important;
        padding: 10px 25px !important;
        font-weight: 600 !important;
        transition: all 0.2s ease !important;
      }

      .btn-danger-solid:hover {
        background: #c82333 !important;
        transform: translateY(-2px) !important;
        box-shadow: 0 4px 12px rgba(220, 53, 69, 0.3) !important;
      }

      /* Tombol TIDAK outline */
      .btn-danger-outline-modern {
        background: transparent !important;
        color: #dc3545 !important;
        border: 2px solid #dc3545 !important;
        border-radius: 12px !important;
        padding: 10px 25px !important;
        font-weight: 600 !important;
        transition: all 0.2s ease !important;
      }

      .btn-danger-outline-modern:hover {
        background: #dc3545 !important;
        color: white !important;
        transform: translateY(-2px) !important;
        box-shadow: 0 4px 12px rgba(220, 53, 69, 0.2) !important;
      }

      /* Styling tambahan untuk judul dan konten */
      .modern-swal .swal2-title {
        font-size: 24px !important;
        font-weight: 700 !important;
        color: #2c5a6e !important;
      }

      .modern-swal .swal2-html-container {
        font-size: 15px !important;
        color: #4a5568 !important;
      }

      .modern-swal .swal2-icon {
        transform: scale(1.1) !important;
      }
    </style>
    <% }) %>
    <% } else { %>
    <div class="no-data">
      <i class="fas fa-calendar-times"></i>
      <p>Tidak ada jadwal untuk hari ini</p>
    </div>
    <% } %>
  </div>
</div>
</div>

<% } else if (page === 'courses') { %>

<!-- KONTEN MATA KULIAH -->
<div class="content-card">
  <h5 class="mb-3">
    <i class="fas fa-book-open me-2"></i>Daftar Mata Kuliah Semester <%= semester %>
  </h5>
  <div class="table-responsive">
    <table class="table-custom">
      <thead>
        <tr>
          <th>No</th>
          <th>Hari</th>
          <th>Mata Kuliah</th>
          <th>Dosen</th>
          <th>SKS</th>
          <th>Kelas</th>
        </tr>
      </thead>
      <tbody>
        <% rows.forEach((r, index) => { %>
        <tr class="matkul-row" onclick="window.location.href='/s/courses/<%= r.slug %>'" style="cursor: pointer;">
          <td><%= index++ +1 %></td>
          <td>
            <% const days = ['Minggu', 'Senin', 'Selasa', 'Rabu', 'Kamis', 'Jumat', 'Sabtu'] 
              const day = days[r.day]
            %>
            <%= day %>
          </td>
          <td><%= r.course_name %></td>
          <td><b><%= r.lecturer_name %>, <%= r.lecturer_degree %></b></td>
          <% if (r.credits === 1) { %>
          <td style="color: greenyellow;"><strong><%= r.credits %></strong></td>
          <% } else if (r.credits === 2) { %>
          <td style="color: #ffc107;"><strong><%= r.credits %></strong></td>
          <% } else { %>
          <td style="color: salmon;"><strong><%= r.credits %></strong></td>
          <% } %>
          <% if (r.class_name.includes('Lokal')) { %>
          <td style="color: rgb(55, 0, 255);"><%= r.class_name %></td>
          <% } else { %>
          <td style="color: rgb(124, 27, 0);"><%= r.class_name %></td>
          <% } %>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
  <div class="alert alert-info mt-3 small">
    <i class="fas fa-info-circle"></i> Klik baris mata kuliah untuk melihat lebih detail.
  </div>
</div>

