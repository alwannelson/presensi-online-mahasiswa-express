<!-- main-layout.ejs - Main Layout Admin -->
<!DOCTYPE html>
<html lang="id">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
  <title><%= title %> | Admin - Jay Presencia</title>

  <!-- Bootstrap 5 CSS -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/css/bootstrap.min.css" rel="stylesheet">
  <!-- Font Awesome 6 -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
  <!-- Google Font: Inter -->
  <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;400;500;600;700;800&display=swap" rel="stylesheet">
  <!-- SweetAlert2 -->
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

  <style>
    * {
      font-family: 'Inter', sans-serif;
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      background: var(--bg-gradient);
      min-height: 100vh;
      padding-bottom: 85px;
      transition: all 0.3s ease;
    }

    /* ========== CSS Variables untuk Theme ========== */
    :root {
      /* Light Theme (Default) */
      --bg-gradient: linear-gradient(135deg, #eef2f7 0%, #dee5ec 100%);
      --card-bg: white;
      --text-primary: #1a2639;
      --text-secondary: #4a5568;
      --border-color: #e2edf2;
      --shadow-color: rgba(0, 0, 0, 0.08);
      --accent-color: #2c5a6e;
      --accent-light: #8cb1c2;
      --success-color: #28a745;
      --danger-color: #dc3545;
      --warning-color: #ffc107;
      --info-color: #17a2b8;
    }

    /* Dark Theme */
    body.dark-theme {
      --bg-gradient: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
      --card-bg: #1e1e2e;
      --text-primary: #e2e8f0;
      --text-secondary: #a0aec0;
      --border-color: #2d3748;
      --shadow-color: rgba(0, 0, 0, 0.3);
      --accent-color: #8cb1c2;
      --accent-light: #2c5a6e;
    }

    /* ========== Main Content ========== */
    .main-container {
      max-width: 1200px;
      margin: 0 auto;
      padding: 20px 20px 0;
    }

    /* ========== Top Bar with Theme Toggle ========== */
    .top-bar {
      background: var(--card-bg);
      border-radius: 24px;
      padding: 16px 24px;
      margin-bottom: 24px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      box-shadow: 0 4px 15px var(--shadow-color);
      border: 1px solid var(--border-color);
      transition: all 0.3s ease;
    }

    .page-title {
      font-size: 24px;
      font-weight: 700;
      color: var(--text-primary);
      margin: 0;
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .page-title i {
      color: var(--accent-light);
      font-size: 28px;
    }

    /* Theme Toggle Button */
    .theme-toggle {
      background: var(--bg-gradient);
      border: 1px solid var(--border-color);
      border-radius: 40px;
      padding: 8px 16px;
      cursor: pointer;
      display: flex;
      align-items: center;
      gap: 10px;
      transition: all 0.3s ease;
    }

    .theme-toggle:hover {
      transform: scale(1.02);
      box-shadow: 0 2px 8px var(--shadow-color);
    }

    .theme-toggle i {
      font-size: 18px;
      color: var(--accent-color);
    }

    .theme-toggle span {
      font-size: 14px;
      font-weight: 500;
      color: var(--text-primary);
    }

    /* ========== Stats Cards ========== */
    .stats-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
      gap: 20px;
      margin-bottom: 30px;
    }

    .stat-card {
      background: var(--card-bg);
      border-radius: 24px;
      padding: 20px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      box-shadow: 0 4px 15px var(--shadow-color);
      border: 1px solid var(--border-color);
      transition: all 0.3s ease;
    }

    .stat-card:hover {
      transform: translateY(-5px);
      box-shadow: 0 8px 25px var(--shadow-color);
    }

    .stat-info h3 {
      font-size: 28px;
      font-weight: 800;
      color: var(--text-primary);
      margin-bottom: 5px;
    }

    .stat-info p {
      font-size: 14px;
      color: var(--text-secondary);
      margin: 0;
    }

    .stat-icon {
      width: 55px;
      height: 55px;
      background: linear-gradient(135deg, var(--accent-light) 0%, var(--accent-color) 100%);
      border-radius: 18px;
      display: flex;
      align-items: center;
      justify-content: center;
      color: white;
      font-size: 24px;
    }

    /* ========== Content Card ========== */
    .content-card {
      background: var(--card-bg);
      border-radius: 24px;
      padding: 24px;
      box-shadow: 0 4px 15px var(--shadow-color);
      border: 1px solid var(--border-color);
      margin-bottom: 24px;
    }

    .card-header-custom {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 20px;
      padding-bottom: 15px;
      border-bottom: 2px solid var(--border-color);
    }

    .card-header-custom h2 {
      font-size: 20px;
      font-weight: 700;
      color: var(--text-primary);
      margin: 0;
    }

    /* ========== Welcome Banner ========== */
    .welcome-banner {
      background: linear-gradient(135deg, var(--accent-color) 0%, var(--accent-light) 100%);
      border-radius: 24px;
      padding: 30px;
      margin-bottom: 30px;
      color: white;
      position: relative;
      overflow: hidden;
    }

    .welcome-banner::before {
      content: '';
      position: absolute;
      top: -50%;
      right: -20%;
      width: 300px;
      height: 300px;
      background: rgba(255, 255, 255, 0.1);
      border-radius: 50%;
    }

    .welcome-banner h1 {
      font-size: 28px;
      font-weight: 800;
      margin-bottom: 8px;
    }

    .welcome-banner p {
      font-size: 14px;
      opacity: 0.9;
      margin: 0;
    }

    /* ========== Animations ========== */
    @keyframes fadeInUp {
      from {
        opacity: 0;
        transform: translateY(20px);
      }

      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    .fade-in {
      animation: fadeInUp 0.5s ease-out;
    }

    /* ========== Responsive ========== */
    @media (max-width: 768px) {
      .main-container {
        padding: 15px 15px 0;
      }

      .stats-grid {
        grid-template-columns: repeat(2, 1fr);
        gap: 15px;
      }

      .stat-card {
        padding: 15px;
      }

      .stat-info h3 {
        font-size: 22px;
      }

      .stat-icon {
        width: 45px;
        height: 45px;
        font-size: 20px;
      }

      .welcome-banner h1 {
        font-size: 22px;
      }
    }
  </style>
</head>

<body>
  <div class="main-container fade-in">
    <!-- Top Bar dengan Theme Toggle -->
    <div class="top-bar">
      <div class="page-title">
        <i class="fas fa-graduation-cap"></i>
        <span>Akademik Japre</span>
      </div>
      <div class="theme-toggle" id="themeToggle">
        <i class="fas fa-moon"></i>
        <span>Mode Gelap</span>
      </div>
    </div>

    <!-- Dynamic Content -->
    <%- body %>
  </div>

  <!-- Bottom Navigation -->
  <%- include('bottom-nav.ejs', { activeMenu: activeMenu }) %>

  <!-- Scripts -->
  <script>
    // ========== Theme Toggle Functionality ==========
    const themeToggle = document.getElementById('themeToggle');
    const body = document.body;

    // Check for saved theme preference
    const savedTheme = localStorage.getItem('theme');
    if (savedTheme === 'dark') {
      body.classList.add('dark-theme');
      updateThemeIcon(true);
    }

    function updateThemeIcon(isDark) {
      const icon = themeToggle.querySelector('i');
      const text = themeToggle.querySelector('span');
      if (isDark) {
        icon.className = 'fas fa-sun';
        text.textContent = 'Mode Terang';
      } else {
        icon.className = 'fas fa-moon';
        text.textContent = 'Mode Gelap';
      }
    }

    themeToggle.addEventListener('click', () => {
      body.classList.toggle('dark-theme');
      const isDark = body.classList.contains('dark-theme');
      localStorage.setItem('theme', isDark ? 'dark' : 'light');
      updateThemeIcon(isDark);
    });

    // ========== Auto hide flash messages ==========
    setTimeout(() => {
      document.querySelectorAll('.alert').forEach(alert => {
        alert.style.transition = 'opacity 0.5s';
        alert.style.opacity = '0';
        setTimeout(() => alert.remove(), 500);
      });
    }, 5000);
  </script>

  <!-- Additional Scripts from child views -->
  <%- scripts || '' %>
</body>

</html>