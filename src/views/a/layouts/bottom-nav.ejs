<style>
    /* Styling Manual untuk Navigasi Utama */
    .bottom-nav-container {
        position: fixed;
        bottom: 15px; /* Memberikan sedikit jarak dari paling bawah layar agar efek melayang terlihat */
        left: 0;
        right: 0;
        z-index: 1000;
        transition: transform 0.4s ease, opacity 0.4s ease; /* Transisi smooth */
        padding: 0 15px; /* Jarak aman kanan-kiri di layar HP */
    }

    .bottom-nav-bar {
        background-color: #ffffff;
        border-radius: 20px; /* REVISI: Penambahan Border Radius melengkung */
        box-shadow: 0 8px 24px rgba(0,0,0,0.08);
        border: 1px solid #eaeaea;
        max-width: 500px; /* Membuat menu berkumpul lebih rapat di tengah */
        margin: 0 auto;
    }
    
    .nav-item-link {
        display: flex;
        flex-direction: column;
        align-items: center;
        text-decoration: none;
        color: #9ca3af; 
        font-size: 11px;
        font-weight: 500;
        transition: all 0.2s ease;
        padding: 10px 12px; /* REVISI: Jarak dalam yang disesuaikan agar antar menu berdekatan */
    }
    
    .nav-item-link i {
        font-size: 22px;
        margin-bottom: 2px;
        transition: transform 0.2s ease;
    }

    /* Efek Hover (Saat kursor menunjuk) */
    .nav-item-link:hover {
        color: #4b5563;
    }

    /* REVISI: Logika menu aktif (isActive) menggunakan Class .active */
    .nav-item-link.active {
        color: #111827 !important; /* Warna teks & ikon menu aktif menjadi gelap pekat */
        font-weight: 600;
    }
    .nav-item-link.active i {
        transform: translateY(-2px); /* Sedikit terangkat untuk penanda aktif */
    }

    /* REVISI: Class pembantu untuk menyembunyikan bottom bar (dipicu oleh JavaScript) */
    .nav-hidden {
        transform: translateY(100px); /* Tergeser ke bawah keluar dari layar */
        opacity: 0;
    }
</style>

<div class="bottom-nav-container" id="bottom-nav">
    <div class="bottom-nav-bar d-flex justify-content-center align-items-center py-1 gap-3">
        
        <a href="#" class="nav-item-link <%= (typeof currentPage !== 'undefined' && currentPage === 'dashboard') ? 'active' : '' %>">
            <i class='bx bx-home-alt'></i>
            <span>Beranda</span>
        </a>
        
        <a href="#" class="nav-item-link <%= (typeof currentPage !== 'undefined' && currentPage === 'pelajaran') ? 'active' : '' %>">
            <i class='bx bx-book-open'></i>
            <span>Pelajaran</span>
        </a>
        
        <a href="#" class="nav-item-link <%= (typeof currentPage !== 'undefined' && currentPage === 'agenda') ? 'active' : '' %>">
            <i class='bx bx-calendar'></i>
            <span>Agenda</span>
        </a>
        
        <a href="#" class="nav-item-link <%= (typeof currentPage !== 'undefined' && currentPage === 'profil') ? 'active' : '' %>">
            <i class='bx bx-user'></i>
            <span>Profil</span>
        </a>
        
    </div>
</div>